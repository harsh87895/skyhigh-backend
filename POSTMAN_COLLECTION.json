      ]
    },
    {
      "name": "Seat Hold and Confirm APIs",
      "description": "POST /api/v1/seats/hold   - Reserve seat for 120 seconds\nPOST /api/v1/seats/confirm - Permanently assign held seat\n\nUses pessimistic locking (SELECT FOR UPDATE) - only one passenger can hold a seat at a time.",
      "item": [
        {
          "name": "Hold a Seat",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('holdId', pm.response.json().holdId);",
                  "}",
                  "pm.test('Status is 201 Created', function () { pm.response.to.have.status(201); });",
                  "pm.test('Hold is ACTIVE', function () {",
                  "    pm.expect(pm.response.json().status).to.eql('ACTIVE');",
                  "});",
                  "pm.test('Expires in ~120s', function () {",
                  "    pm.expect(pm.response.json().remainingSeconds).to.be.within(115, 120);",
                  "});"
                ]
              }
            }
          ],
          "request": {
