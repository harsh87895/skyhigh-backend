                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/flights/SK101/seats/available/count",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "flights", "SK101", "seats", "available", "count"]
            },
            "description": "GET /api/v1/flights/{flightId}/seats/available/count\n\nReturns integer count of AVAILABLE seats for the flight."
          }
