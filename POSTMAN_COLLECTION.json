            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/seats/hold",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "seats", "hold"]
            },
            "description": "POST /api/v1/seats/hold\n\nRequest body:\n- checkInId (UUID, required)\n- flightId (string, required)\n- seatNumber (string, required): e.g. 1A, 2C, 5F\n\nReturns 201 with holdId, expiresAt, remainingSeconds.\nErrors:\n- 409 seat already HELD or CONFIRMED\n- 422 check-in not IN_PROGRESS\n- 404 check-in or seat not found"
          }
