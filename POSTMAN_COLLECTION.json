{
  "info": {
    "_postman_id": "skyhigh-core-api-collection",
    "name": "SkyHigh Core - Digital Check-In API",
    "description": "Complete API collection for SkyHigh Airlines Digital Check-In System.\n\nPrerequisites:\n1. Start services: docker-compose up --build\n2. App runs at http://localhost:8080\n\nSample data loaded automatically:\n- Passengers: P001 (John Doe), P002 (Jane Smith), P003-P005\n- Flights: SK101 (LAX to JFK), SK102 (JFK to LAX)\n- Seats: 30 economy seats for SK101 (rows 1-5, columns A-F)\n\nRun folders in order for end-to-end flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "Base URL of the SkyHigh Core API"
    },
    {
      "key": "checkInId",
      "value": "",
      "type": "string",
      "description": "Auto-populated from Start Check-In response"
    },
    {
      "key": "holdId",
      "value": "",
      "type": "string",
      "description": "Auto-populated from Hold Seat response"
    }
  ],
  "item": [
    {
      "name": "Happy Path - Full Check-In Flow (Run In Order)",
      "description": "Complete end-to-end check-in: no excess baggage, no payment required.\nOrder: Step1 > Step2 > Step3 > Step4 > Step5 > Step6",
      "item": [
        {
          "name": "Step 1 - Start Check-In",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', function () { pm.response.to.have.status(201); });",
                  "pm.test('Has checkInId', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.checkInId).to.be.a('string');",
                  "    pm.collectionVariables.set('checkInId', json.checkInId);",
                  "});",
                  "pm.test('Status is IN_PROGRESS', function () {",
                  "    pm.expect(pm.response.json().status).to.eql('IN_PROGRESS');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"passengerId\": \"P001\",\n  \"flightId\": \"SK101\",\n  \"bookingReference\": \"BK001001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/check-in/start",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "check-in", "start"]
            },
            "description": "POST /api/v1/check-in/start\n\nInitiate check-in for passenger P001 on flight SK101.\nSaves checkInId to collection variable automatically."
          }
        },
        {
          "name": "Step 2 - Browse Seat Map",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () { pm.response.to.have.status(200); });",
                  "pm.test('Has seats array', function () {",
                  "    pm.expect(pm.response.json().seats).to.be.an('array').and.have.lengthOf.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/flights/SK101/seats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "flights", "SK101", "seats"]
            },
            "description": "GET /api/v1/flights/{flightId}/seats\n\nFetch full seat map for SK101. Cached in Redis (2s TTL) for P95 < 1s."
          }
        },
        {
          "name": "Step 3 - Validate Baggage (20kg - within free limit)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', function () { pm.response.to.have.status(201); });",
                  "pm.test('Payment NOT required for 20kg', function () {",
                  "    pm.expect(pm.response.json().paymentRequired).to.eql(false);",
                  "});",
                  "pm.test('No excess fee', function () {",
                  "    pm.expect(pm.response.json().excessFee).to.be.null;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"checkInId\": \"{{checkInId}}\",\n  \"weight\": 20.0,\n  \"pieces\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/baggage/validate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "baggage", "validate"]
            },
            "description": "POST /api/v1/baggage/validate\n\n20kg baggage - within the 25kg free limit. No payment required.\nFee formula: (weight - 25) * 10 per kg. Result: $0."
          }
        },
        {
          "name": "Step 4 - Hold Seat 1A (120s reservation)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', function () { pm.response.to.have.status(201); });",
                  "pm.test('Has holdId', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.holdId).to.be.a('string');",
                  "    pm.collectionVariables.set('holdId', json.holdId);",
                  "});",
                  "pm.test('Hold is ACTIVE', function () {",
                  "    pm.expect(pm.response.json().status).to.eql('ACTIVE');",
                  "});",
                  "pm.test('About 120 seconds remaining', function () {",
                  "    pm.expect(pm.response.json().remainingSeconds).to.be.within(115, 120);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"checkInId\": \"{{checkInId}}\",\n  \"flightId\": \"SK101\",\n  \"seatNumber\": \"1A\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/seats/hold",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "seats", "hold"]
            },
            "description": "POST /api/v1/seats/hold\n\nReserve seat 1A using pessimistic locking (SELECT FOR UPDATE).\nOnly ONE passenger can hold this seat simultaneously.\nHold expires after 120 seconds. Saves holdId to collection variable."
          }
        },
        {
          "name": "Step 5 - Confirm Seat 1A",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () { pm.response.to.have.status(200); });",
                  "pm.test('Seat CONFIRMED', function () {",
                  "    pm.expect(pm.response.json().status).to.eql('CONFIRMED');",
                  "});",
                  "pm.test('Seat number is 1A', function () {",
                  "    pm.expect(pm.response.json().seatNumber).to.eql('1A');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"holdId\": \"{{holdId}}\",\n  \"checkInId\": \"{{checkInId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/seats/confirm",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "seats", "confirm"]
            },
            "description": "POST /api/v1/seats/confirm\n\nPermanently assign seat 1A. Must be done within 120 seconds.\nSeat transitions: HELD -> CONFIRMED (immutable)."
          }
        },
        {
          "name": "Step 6 - Complete Check-In",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () { pm.response.to.have.status(200); });",
                  "pm.test('Check-in COMPLETED', function () {",
                  "    pm.expect(pm.response.json().status).to.eql('COMPLETED');",
                  "});",
                  "pm.test('completedAt is set', function () {",
                  "    pm.expect(pm.response.json().completedAt).to.not.be.null;",
                  "});",
                  "pm.test('Seat 1A assigned', function () {",
                  "    pm.expect(pm.response.json().seatNumber).to.eql('1A');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/check-in/{{checkInId}}/complete",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "check-in", "{{checkInId}}", "complete"]
            },
            "description": "POST /api/v1/check-in/{checkInId}/complete\n\nFinalize the check-in. Requires seat to be CONFIRMED.\nSets status to COMPLETED and records completedAt timestamp."
          }
        }
      ]
    },
    {
      "name": "Excess Baggage Payment Flow (Run In Order)",
      "description": "End-to-end flow for passenger with baggage over 25kg free limit.\nOrder: Step1 > Step2 (excess fee) > Step3 (payment) > Step4 > Step5 > Step6",
      "item": [
        {
          "name": "Step 1 - Start Check-In (P002)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "pm.collectionVariables.set('checkInId', pm.response.json().checkInId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"passengerId\": \"P002\",\n  \"flightId\": \"SK101\",\n  \"bookingReference\": \"BK002001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/check-in/start",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "check-in", "start"]
            }
          }
        },
        {
          "name": "Step 2 - Validate Excess Baggage (30kg = $50 fee)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Payment IS required', function () {",
                  "    pm.expect(pm.response.json().paymentRequired).to.eql(true);",
                  "});",
                  "pm.test('Excess fee is $50 (5kg * $10)', function () {",
                  "    pm.expect(pm.response.json().excessFee).to.eql(50.00);",
                  "});",
                  "pm.test('Excess weight is 5kg', function () {",
                  "    pm.expect(pm.response.json().excessWeight).to.eql(5.0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"checkInId\": \"{{checkInId}}\",\n  \"weight\": 30.0,\n  \"pieces\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/baggage/validate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "baggage", "validate"]
            },
            "description": "30kg baggage: 5kg over limit. Fee = 5 * $10 = $50.\nCheck-in status becomes AWAITING_PAYMENT."
          }
        },
        {
          "name": "Step 3 - Process Payment ($50)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () { pm.response.to.have.status(200); });",
                  "pm.test('Payment succeeded', function () {",
                  "    pm.expect(pm.response.json().success).to.eql(true);",
                  "});",
                  "pm.test('Transaction ID generated', function () {",
                  "    pm.expect(pm.response.json().transactionId).to.match(/^TXN-/);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"checkInId\": \"{{checkInId}}\",\n  \"amount\": 50.00,\n  \"paymentMethod\": \"CREDIT_CARD\",\n  \"cardToken\": \"tok_mock_visa_4242\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payment/process",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payment", "process"]
            },
            "description": "MOCK payment endpoint - always succeeds.\nCheck-in status resumes to IN_PROGRESS after payment."
          }
        },
        {
          "name": "Step 4 - Hold Seat 2A",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "pm.collectionVariables.set('holdId', pm.response.json().holdId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"checkInId\": \"{{checkInId}}\",\n  \"flightId\": \"SK101\",\n  \"seatNumber\": \"2A\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/seats/hold",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "seats", "hold"]
            }
          }
        },
        {
          "name": "Step 5 - Confirm Seat 2A",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"holdId\": \"{{holdId}}\",\n  \"checkInId\": \"{{checkInId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/seats/confirm",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "seats", "confirm"]
            }
          }
        },
        {
          "name": "Step 6 - Complete Check-In",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/check-in/{{checkInId}}/complete",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "check-in", "{{checkInId}}", "complete"]
            }
          }
        }
      ]
    },
    {
      "name": "Check-In APIs",
      "description": "POST /api/v1/check-in/start\nGET  /api/v1/check-in/{checkInId}\nPOST /api/v1/check-in/{checkInId}/complete\nDELETE /api/v1/check-in/{checkInId}",
      "item": [
        {
          "name": "Start Check-In",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('checkInId', pm.response.json().checkInId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"passengerId\": \"P003\",\n  \"flightId\": \"SK101\",\n  \"bookingReference\": \"BK003001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/check-in/start",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "check-in", "start"]
            },
            "description": "POST /api/v1/check-in/start\n\nRequest body:\n- passengerId (string, required): P001-P005 (pre-loaded)\n- flightId (string, required): SK101 or SK102\n- bookingReference (string, required): any string\n\nReturns 201 with checkInId.\nErrors: 404 flight not found, 409 duplicate check-in."
          }
        },
        {
          "name": "Get Check-In by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/check-in/{{checkInId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "check-in", "{{checkInId}}"]
            },
            "description": "GET /api/v1/check-in/{checkInId}\n\nRetrieve check-in details. Returns 404 if not found."
          }
        },
        {
          "name": "Complete Check-In",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/check-in/{{checkInId}}/complete",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "check-in", "{{checkInId}}", "complete"]
            },
            "description": "POST /api/v1/check-in/{checkInId}/complete\n\nPrerequisites:\n1. Seat must be CONFIRMED\n2. No pending payment (not AWAITING_PAYMENT)\n\nSets status to COMPLETED."
          }
        },
        {
          "name": "Cancel Check-In",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/check-in/{{checkInId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "check-in", "{{checkInId}}"]
            },
            "description": "DELETE /api/v1/check-in/{checkInId}\n\nCancels check-in and releases any active seat holds.\nReturns 204 No Content."
          }
        }
      ]
    },
    {
      "name": "Flight and Seat Map APIs",
      "description": "GET /api/v1/flights/{flightId}/seats\nGET /api/v1/flights/{flightId}/seats?seatClass=ECONOMY&position=WINDOW\nGET /api/v1/flights/{flightId}/seats/available/count\n\nCached in Redis with 2s TTL. P95 < 1s.",
      "item": [
        {
          "name": "Get Full Seat Map - SK101",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Has seats', function () {",
                  "    pm.expect(pm.response.json().seats).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/flights/SK101/seats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "flights", "SK101", "seats"]
            },
            "description": "Returns all seats for SK101 with their status.\nCached 2 seconds in Redis. First call is DB query, subsequent within 2s are cache hits."
          }
        },
        {
          "name": "Get Seat Map - Economy Class Only",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/flights/SK101/seats?seatClass=ECONOMY",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "flights", "SK101", "seats"],
              "query": [{ "key": "seatClass", "value": "ECONOMY" }]
            },
            "description": "Filter by seatClass. Options: ECONOMY, BUSINESS, FIRST"
